# --- Typography ---
font = "JetBrainsMono Nerd Font"
font-size = 16
text-cursor-style = bar

# --- Gruvbox Color Palette ---
# Base text (Gruvbox Foreground)
text-color = #ebdbb2

# The "run:" prompt color (Gruvbox Green)
prompt-color = #b8bb26
prompt-text = "run: "

# Background color (Gruvbox Dark Base)
background-color = #282828

# Selected item text (Gruvbox Yellow)
selection-color = #fabd2f

# Selected item background (Gruvbox Dark Alt - gives a nice highlight box)
selection-background = #3c3836

# Matching portion of text (Gruvbox Red - makes the exact letters you typed pop)
selection-match-color = #fb4934

# --- Window & Borders ---
width = 400
height = 256
anchor = center

# Border matching your Hyprland/Waybar green active borders
outline-width = 0
border-width = 3
border-color = #b8bb26

# Matched to your Waybar border-radius for system consistency
corner-radius = 12

padding-top = 10
padding-bottom = 10
padding-left = 10
padding-right = 10

# --- Behavior ---
text-cursor = true
history = true
require-match = true
ascii-input = false

# Changed to fuzzy so you don't have to type exact starting letters!
matching-algorithm = fuzzy
